## Add code to filter interactive data table with MongoDB queries
def update_dashboard(filter_type):
    query = {}
    if filter_type == 'water_rescue':
        query = {"animal_type": "Dog", "breed": {"$in": ["Labrador Retriever", "Newfoundland"]}}
    elif filter_type == 'mountain_wilderness_rescue':
        query = {"animal_type": "Dog", "breed": {"$in": ["German Shepherd", "Alaskan Malamute", "Old English Sheepdog", "Siberian Husky", "Rottweiler"]}}
    elif filter_type == 'disaster_individual_tracking':
        query = {"animal_type": "Dog", "breed": {"$in": ["Doberman Pinscher", "German Shepherd", "Golden Retriever", "Bloodhound", "Rottweiler"]}}
    else:
        # Default query to show all or a safe default if nothing is selected
        query = {} 

    # Fetch data
    results = list(db.read(query))
    if not results: # Handle empty return
        return [], []
        
    data = pd.DataFrame.from_records(results)
    if '_id' in data.columns:
        data.drop(columns=['_id'], inplace=True)
        
    records = data.to_dict('records')
    columns = [{"name": i, "id": i} for i in data.columns]
    
    return records, columns

# Display the breeds of animal based on quantity represented in
# the data table
@app.callback(
    Output('graph-id', "children"),
    [Input('datatable-id', "derived_virtual_data")]
)
def update_graphs(viewData):
    #FIXED: Added code for a pie chart displaying breed distribution
    if viewData is None or len(viewData) == 0:
        return html.Div("No data available to display.")
    
    dff = pd.DataFrame.from_dict(viewData)
    fig = px.pie(dff, names='breed', title='Preferred Animals by Breed')
    return [
        dcc.Graph(
            figure=fig
        )]

    ###FIX ME ####
    """
    Creates a pie chart based on the data currently in the DataTable.
    """
    if viewData is None:
        return []

    dff = pd.DataFrame.from_dict(viewData)

    # Check if df is empty to avoid px.pie errors
    if dff.empty:
        # Using a simple message for no data available
        return [dcc.Graph(figure=px.pie(title="No Data Available"))]

    # Plotly Express automatically groups repeated names, so we can use the 'breed' column directly
    fig = px.pie(dff, names='breed', title='Preferred Animals')

    # To "explode" all slices, use a constant pull value in update_traces.
    # A pull value is a fraction of the pie radius (e.g., 0.1 for a slight pull).
    # You can customize this value as needed.
    fig.update_traces(pull=0.1) #

    # For a more controlled "explode" effect where only specific slices are pulled,
    # you would need an array of pull values (0 for no pull, >0 for pull)
    # matching the order of the data points.

    return [dcc.Graph(figure=fig)]
#This callback will highlight a cell on the data table when the user selects it
@app.callback(
Output('datatable-id', 'style_data_conditional'),
    [Input('datatable-id', 'selected_columns')]
)
def update_styles(selected_columns):
    if selected_columns is None:
        return []

    return [{
        'if': {'column_id': i},
        'background_color': '#D2F3FF'
    } for i in selected_columns]

# This callback will update the geo-location chart for the selected data entry
# derived_virtual_data will be the set of data available from the datatable in the form of 
# a dictionary.
# derived_virtual_selected_rows will be the selected row(s) in the table in the form of
# a list. For this application, we are only permitting single row selection so there is only
# one value in the list.
# The iloc method allows for a row, column notation to pull data from the datatable
@app.callback(
    Output('map-id', "children"),
    [Input('datatable-id', "derived_virtual_data"),
    Input('datatable-id', "derived_virtual_selected_rows")])
def update_map(viewData, index):  
    if viewData is None:
        return 
    
    dff = pd.DataFrame.from_dict(viewData)
    # Because we only allow single row selection, the list can be converted to a row index here
    if index is None or len(index) == 0:
        row = 0 #Default to first row
    else: 
        row = index[0]
        
    # Austin TX is at [30.75,-97.48]
    return [
        dl.Map(style={'width': '1000px', 'height': '500px'}, center=[30.75,-97.48], zoom=10, children=[
            dl.TileLayer(id="base-layer-id"),
            # Marker with tool tip and popup
            # Column 13 and 14 define the grid-coordinates for the map
            # Column 4 defines the breed for the animal
            # Column 9 defines the name of the animal
            dl.Marker(position=[dff.iloc[row,13],dff.iloc[row,14]], children=[
                dl.Tooltip(dff.iloc[row,4]),
                dl.Popup([
                    html.H1("Animal Name"),
                    html.P(dff.iloc[row,9])
                ])
            ])
    ])
]


